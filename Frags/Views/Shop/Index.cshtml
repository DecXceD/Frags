@model IEnumerable<Frags.Data.Models.Fragrance>
@{
    ViewData["Title"] = "Shop";
}

<h2 class="mb-4">Shop</h2>

<p class="text-muted">@ViewBag.TotalItems results found</p>

<form method="get" class="row g-2 mb-4">

    <div class="col-md-3">
        <input type="text" id="searchInput" name="search" class="form-control"
               placeholder="Search fragrance..."
               value="@Context.Request.Query["search"]" />
    </div>

    <div class="col-md-2">
        <select name="brandId" class="form-control" onchange="this.form.submit()">
            <option value="">All Brands</option>
            @foreach (var b in ViewBag.Brands)
            {
                <option value="@b.Id"
                        selected="@(Context.Request.Query["brandId"] == b.Id.ToString())">
                    @b.Name
                </option>
            }
        </select>
    </div>

    <div class="col-md-2">
        <select name="categoryId" class="form-control" onchange="this.form.submit()">
            <option value="">All Categories</option>
            @foreach (var c in ViewBag.Categories)
            {
                <option value="@c.Id"
                        selected="@(Context.Request.Query["categoryId"] == c.Id.ToString())">
                    @c.Name
                </option>
            }
        </select>
    </div>

    <div class="col-md-2">
        <select name="gender" class="form-control" onchange="this.form.submit()">
            <option value="">All Genders</option>
            <option value="Men" selected="@(Context.Request.Query["gender"] == "Men")">Men</option>
            <option value="Women" selected="@(Context.Request.Query["gender"] == "Women")">Women</option>
            <option value="Unisex" selected="@(Context.Request.Query["gender"] == "Unisex")">Unisex</option>
        </select>
    </div>

    <div class="col-md-2">
        <select name="sort" class="form-control" onchange="this.form.submit()">
            <option value="">Sort by</option>
            <option value="price_asc" selected="@(Context.Request.Query["sort"] == "price_asc")">Price ↑</option>
            <option value="price_desc" selected="@(Context.Request.Query["sort"] == "price_desc")">Price ↓</option>
            <option value="name" selected="@(Context.Request.Query["sort"] == "name")">Name</option>
        </select>
    </div>

    <div class="col-md-1">
        <button type="submit" class="btn btn-dark w-100">Filter</button>
    </div>

</form>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-3 mb-4">
            <div class="card h-100 shadow-sm">

                <a asp-controller="Shop" asp-action="Details" asp-route-id="@item.Id">
                    <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" />
                </a>

                <div class="card-body text-center">

                    <p class="text-muted small mb-1">
                        <a asp-controller="Brands"
                               asp-action="Details"
                               asp-route-id="@item.BrandId"
                               class="text-muted text-decoration-none">
                            @item.Brand?.Name
                        </a>
                    </p>

                    <h5 class="card-title text-truncate">
                        <a asp-controller="Shop" asp-action="Details" asp-route-id="@item.Id"
                               class="text-dark text-decoration-none">
                            @item.Name
                        </a>
                    </h5>

                    <p class="text-secondary small mb-1">
                        <a asp-controller="Categories"
                               asp-action="Details"
                               asp-route-id="@item.CategoryId"
                               class="text-secondary text-decoration-none">
                            @item.Category?.Name
                        </a>
                    </p>

                    <p class="text-muted small">@item.Gender</p>

                    <p class="fw-bold">$@item.Price</p>

                    <a asp-controller="Cart"
                           asp-action="Add"
                           asp-route-id="@item.Id"
                           class="btn btn-dark btn-sm mt-2">
                        Add to Cart
                    </a>

                </div>
            </div>
        </div>
    }
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4 text-center">

        @if (ViewBag.CurrentPage > 1)
        {
            <a asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-search="@Context.Request.Query["search"]"
                   asp-route-brandId="@Context.Request.Query["brandId"]"
                   asp-route-categoryId="@Context.Request.Query["categoryId"]"
                   asp-route-gender="@Context.Request.Query["gender"]"
                   asp-route-sort="@Context.Request.Query["sort"]"
                   class="btn btn-outline-dark me-2">
                ← Previous
            </a>
        }

        <ul class="pagination justify-content-center d-inline-flex">

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a asp-action="Index"
                           asp-route-page="@i"
                           asp-route-search="@Context.Request.Query["search"]"
                           asp-route-brandId="@Context.Request.Query["brandId"]"
                           asp-route-categoryId="@Context.Request.Query["categoryId"]"
                           asp-route-gender="@Context.Request.Query["gender"]"
                           asp-route-sort="@Context.Request.Query["sort"]"
                           class="page-link">
                        @i
                    </a>
                </li>
            }

        </ul>

        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
        {
            <a asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-search="@Context.Request.Query["search"]"
                   asp-route-brandId="@Context.Request.Query["brandId"]"
                   asp-route-categoryId="@Context.Request.Query["categoryId"]"
                   asp-route-gender="@Context.Request.Query["gender"]"
                   asp-route-sort="@Context.Request.Query["sort"]"
                   class="btn btn-outline-dark ms-2">
                Next →
            </a>
        }

    </nav>
}

@section Scripts {
    <script>
        let timeout = null;

        const searchInput = document.getElementById("searchInput");

        if (searchInput) {
            searchInput.addEventListener("input", function () {
                clearTimeout(timeout);

                timeout = setTimeout(() => {
                    this.form.submit();
                }, 1000);
            });
        }
    </script>
}
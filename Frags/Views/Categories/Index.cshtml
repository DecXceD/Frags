@using Frags.Services.ViewModels.Category
@model IEnumerable<CategoryFormModel>

<h2>Categories</h2>

<ul class="list-group">
    @foreach (var category in Model)
    {
        <li class="list-group-item">
            <a asp-action="Details" asp-route-id="@category.Id">
                @category.Name
            </a>
        </li>
    }
</ul>

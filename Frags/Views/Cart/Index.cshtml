@using Frags.Data.Models
@model IEnumerable<CartItem>

@{
    var total = Model.Sum(x => x.Quantity * x.Fragrance.Price);
}

<h2>Your Cart</h2>

@if (!Model.Any())
{
    <p class="text-muted">Your cart is empty.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Fragrance</th>
                <th>Brand</th>
                <th>Price</th>
                <th style="width: 140px;">Quantity</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Fragrance.Name</td>
                    <td>@item.Fragrance.Brand?.Name</td>
                    <td>$@item.Fragrance.Price</td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <a asp-action="Decrease" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-secondary">-</a>

                            <span>@item.Quantity</span>

                            <a asp-action="Increase" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-secondary">+</a>
                        </div>
                    </td>
                    <td class="text-end">
                        <a asp-action="Remove"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-danger">
                            Remove
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <h4 class="mt-3 text-end">Total: $@total.ToString("F2")</h4>
}

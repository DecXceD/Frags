@model IEnumerable<Frags.Services.ViewModels.Brand.BrandFormModel>

<h2>Manage Brands</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Create</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th style="width:150px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var brand in Model)
        {
            <tr>
                <td>@brand.Name</td>
                <td>
                    <a asp-action="Delete" asp-route-id="@brand.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>